                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Border Background="#1a1a1a" BorderBrush="#333333" BorderThickness="1" CornerRadius="4" Padding="5" Width="150" Margin="0,0,10,0">
                                                            <TextBox x:Name="versionHashBox" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextForeground}" FontFamily="{StaticResource com}" FontSize="12" VerticalContentAlignment="Center" Tag="Version Hash..." TextChanged="versionHashBox_TextChanged"/>
                                                        </Border>
                                                        <Button x:Name="installVersionBtn" Content="Install" Width="80" Height="26" Click="InstallVersion_Click" IsEnabled="False" Style="{StaticResource KeyButtonStyle}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,25">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Quick Actions" Foreground="{DynamicResource TextForeground}" FontFamily="{StaticResource com}" FontSize="16" Margin="0,0,0,5"/>
                                                        <TextBlock Text="Quickly fetch the live or latest pre-build version" Foreground="{DynamicResource TextForegroundSecondary}" FontFamily="{StaticResource com}" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="Use Live" Width="80" Height="26" Margin="0,0,5,0" Click="UseLiveVersion_Click" Style="{StaticResource KeyButtonStyle}"/>
                                                        <Button Content="Use Latest" Width="90" Height="26" Click="UseLatestPreBuild_Click" Style="{StaticResource KeyButtonStyle}"/>
                                                    </StackPanel>
                                                </Grid>

                                                <Grid Margin="0,0,0,25">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Roblox Utilities" Foreground="{DynamicResource TextForeground}" FontFamily="{StaticResource com}" FontSize="16" Margin="0,0,0,5"/>
                                                        <TextBlock Text="Open Roblox or its installation directory" Foreground="{DynamicResource TextForegroundSecondary}" FontFamily="{StaticResource com}" FontSize="12"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Button Content="Launch Roblox" Width="104" Height="30" Margin="0,0,8,0" Click="OpenRoblox_Click" Style="{StaticResource KeyButtonStyle}"/>
                                                        <Button Content="Open Folder" Width="96" Height="30" Click="OpenRobloxFolder_Click" Style="{StaticResource KeyButtonStyle}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>

                                    <Grid x:Name="HelpSettings" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5" Opacity="0">
                                        <Grid.RenderTransform>
                                            <TranslateTransform Y="50"/>
                                        </Grid.RenderTransform>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0">
                                            <TextBlock Text="Help &amp; Support" Foreground="{DynamicResource TextForeground}" FontFamily="{StaticResource com}" FontSize="24" FontWeight="Regular"/>
                                            <TextBlock Text="Need help? Join our community or visit our website." Foreground="{DynamicResource TextForegroundSecondary}" FontFamily="{StaticResource com}" FontSize="13" Margin="0,5,0,20"/>
                                            <Rectangle Height="1" Fill="#333333" Margin="0,0,0,20"/>
                                        </StackPanel>

                                        <ScrollViewer Grid.Row="1" Style="{StaticResource TransparentScrollViewerStyle}" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                            <StackPanel Margin="0,0,6,0">
                                                <Grid Margin="0,0,0,25">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Discord Server" Foreground="{DynamicResource TextForeground}" FontFamily="{StaticResource com}" FontSize="16" Margin="0,0,0,5"/>
                                                        <TextBlock Text="Join our Discord for support and updates" Foreground="{DynamicResource TextForegroundSecondary}" FontFamily="{StaticResource com}" FontSize="12"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Join Discord" Width="120" Height="30" Click="JoinDiscord_Click" Style="{StaticResource KeyButtonStyle}"/>
                                                </Grid>

                                                <Grid Margin="0,0,0,25">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="Official Website" Foreground="{DynamicResource TextForeground}" FontFamily="{StaticResource com}" FontSize="16" Margin="0,0,0,5"/>
                                                        <TextBlock Text="Visit our website for more information" Foreground="{DynamicResource TextForegroundSecondary}" FontFamily="{StaticResource com}" FontSize="12"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Visit Website" Width="120" Height="30" Click="VisitWebsite_Click" Style="{StaticResource KeyButtonStyle}"/>
                                                </Grid>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Grid>

                                <Border x:Name="ClearLogDialogue" Grid.ColumnSpan="2" Visibility="Collapsed" Background="#aa000000" CornerRadius="12" Panel.ZIndex="200">
                                    <Border x:Name="ClearLogPanel" Width="260" Background="#111111" BorderBrush="#333333" BorderThickness="1" CornerRadius="12" RenderTransformOrigin="0.5,0.5" Padding="20" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Border.RenderTransform>
                                            <ScaleTransform/>
                                        </Border.RenderTransform>
                                        <StackPanel>
                                            <TextBlock Text="Clear Logs" Foreground="#ffffff" FontFamily="{StaticResource com}" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                                            <Rectangle Height="1" Fill="#222222" Margin="0,0,0,15"/>

                                            <Grid Margin="0,0,0,12">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Current Log" Foreground="#dddddd" FontFamily="{StaticResource com}" FontSize="13" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="ClearCurrentLogCheck" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"/>
                                            </Grid>

                                            <Grid Margin="0,0,0,20">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Old Log Files" Foreground="#dddddd" FontFamily="{StaticResource com}" FontSize="13" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="ClearOldLogsCheck" Grid.Column="1" IsChecked="True" Style="{StaticResource ToggleSwitchStyle}"/>
                                            </Grid>

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <Button Content="Delete" Width="90" Height="28" Margin="0,0,6,0" Click="ClearLog_Confirm_Click" Style="{StaticResource KeyButtonStyle}"/>
                                                <Button Content="Cancel" Width="90" Height="28" Margin="6,0,0,0" Click="ClearLog_Cancel_Click" Style="{StaticResource KeyButtonStyle}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>
